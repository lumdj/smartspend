# ─────────────────────────────────────────────────────────────────────────────
# SmartSpend Environment Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control — it contains secrets.
# .env is already in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Local development:
DATABASE_URL=postgresql://postgres:password@localhost:5432/smartspend
# Render (production) — paste your Render PostgreSQL connection string here:
# DATABASE_URL=postgresql://user:password@host:5432/smartspend

# ── Anthropic ─────────────────────────────────────────────────────────────────
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Data Source ───────────────────────────────────────────────────────────────
# Options: synthetic | plaid | stripe
DATA_SOURCE=synthetic

# ── App Environment ───────────────────────────────────────────────────────────
# Options: development | production | test
ENVIRONMENT=development

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# Development:
ALLOWED_ORIGINS=http://localhost:5173
# Production (add your Vercel URL):
# ALLOWED_ORIGINS=http://localhost:5173,https://smartspend.vercel.app

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# Requests per minute per IP
RATE_LIMIT_PER_MINUTE=60
